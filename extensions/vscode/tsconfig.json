{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2021"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"],
    "typeRoots": ["../../packages/core/node_modules/@types", "node_modules/@types"],
    "baseUrl": ".",
    "paths": {
      "@package-workbench/core": ["../../packages/core/src/index.ts"],
      "@package-workbench/plugin-sdk": ["../../packages/plugin-sdk/src/index.ts"],
      "@package-workbench/chat-engine": ["../../packages/chat-engine/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/test/**"]
}
