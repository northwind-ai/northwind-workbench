{
  "name": "@package-workbench/nx-adapter",
  "version": "0.0.1",
  "description": "Nx workspace adapter for Package Workbench — reference plugin implementation.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@package-workbench/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@package-workbench/plugin-sdk": "workspace:*",
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5",
    "tsup": "^8.1.0"
  }
}
