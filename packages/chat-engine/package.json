{
  "name": "@package-workbench/chat-engine",
  "version": "0.0.1",
  "description": "AI Codebase Chat — natural-language Q&A over Package Workbench intelligence. Offline heuristic reasoning, optional LLM.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@package-workbench/core": "workspace:*",
    "@package-workbench/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "20.19.43",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  }
}
